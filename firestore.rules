rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSupervisorDomain() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@hispresencechurch\\.ca$');
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isSupervisorDomain();
    }

    match /volunteers/{volunteerId} {
      allow create: if request.resource.data.browserTokenHash == volunteerId;
      allow read: if isSupervisorDomain()
        || volunteerId.matches('[0-9a-f]{64}');
      allow update: if isSupervisorDomain()
        || (
          resource.data.browserTokenHash == volunteerId
          && request.resource.data.browserTokenHash == volunteerId
        );
      allow delete: if isSupervisorDomain();
    }

    match /volunteerLookups/{lookupId} {
      allow read: if true;
      allow create, update: if request.resource.data.volunteerId is string;
      allow delete: if isSupervisorDomain();
    }

    match /attendanceSessions/{sessionId} {
      allow create: if request.resource.data.volunteerTokenHash is string
        && sessionId.matches('.*_' + request.resource.data.volunteerTokenHash + '$');
      allow read: if isSupervisorDomain()
        || sessionId.matches('.*_[0-9a-f]{64}$');
      allow update: if isSupervisorDomain()
        || (
          resource.data.volunteerTokenHash is string
          && sessionId.matches('.*_' + resource.data.volunteerTokenHash + '$')
          && request.resource.data.volunteerTokenHash == resource.data.volunteerTokenHash
        );
      allow delete: if isSupervisorDomain();
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isSupervisorDomain();
      allow update: if isSupervisorDomain()
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedVolunteerIds', 'updatedAt'])
          && request.resource.data.assignedVolunteerIds is list
          && resource.data.assignedVolunteerIds is list
          && resource.data.status == 'in-progress'
          && request.resource.data.status == resource.data.status
          && request.resource.data.assignedVolunteerIds.hasAll(resource.data.assignedVolunteerIds)
        );
    }

    match /taskFeedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if isSupervisorDomain();
    }

    match /activityLogs/{activityId} {
      allow create: if request.resource.data.eventId is string
        && request.resource.data.siteId is string
        && (
          request.resource.data.kind == 'check-in'
          || request.resource.data.kind == 'check-out'
          || request.resource.data.kind == 'task-assigned'
          || request.resource.data.kind == 'task-unassigned'
          || request.resource.data.kind == 'task-joined'
        )
        && request.resource.data.message is string;
      allow read, update, delete: if isSupervisorDomain();
    }
  }
}
